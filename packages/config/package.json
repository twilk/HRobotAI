{
  "name": "@hrobot/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./eslint": "./eslint.config.mjs",
    "./prettier": "./prettier.config.cjs"
  },
  "files": ["dist", "tsconfig.base.json", "eslint.config.mjs", "prettier.config.cjs"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:integration": "jest --testMatch '**/*.integration.spec.ts' --passWithNoTests",
    "db:generate": "echo \"no db in @hrobot/config\""
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "typescript-eslint": "^8.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
  }
}
