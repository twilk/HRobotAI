generator client {
  provider = "prisma-client-js"
  output   = "../../generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PRACOWNIK
  MANAGER
  HR
  ADMIN_KLIENTA
}

enum EmploymentType {
  UMOWA_O_PRACE
  UMOWA_ZLECENIE
  UMOWA_O_DZIELO
  B2B
}

/// Where a ShiftDemand came from: expanded from a ShiftTemplate, or entered by hand.
enum DemandSource {
  TEMPLATE
  MANUAL
}

/// How a Shift was produced: by the grafik solver (auto), or placed/edited by a human.
enum ShiftSource {
  AUTO
  MANUAL
}

/// Lifecycle of a shift-swap request (M2 #3). DRAFT → PENDING_PEER → PEER_AGREED →
/// PENDING_MANAGER → APPROVED, with REJECTED/CANCELLED as terminal off-ramps.
enum SwapState {
  DRAFT
  PENDING_PEER
  PEER_AGREED
  PENDING_MANAGER
  APPROVED
  REJECTED
  CANCELLED
}

/// Lifecycle of a leave request (urlop) (M2 leave support). PENDING is the default: leave enters an
/// approval flow (see `nextLeaveState` in @hrobot/shared) and only becomes APPROVED/REJECTED/CANCELLED
/// via an explicit decision. Only APPROVED leave feeds the grafik solver as an H3 hard constraint.
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AutonomyLevel {
  SUGGEST_ONLY
  AUTO_NOTIFY
  AUTO_ASK_CONSENT
  AUTO_COMMIT_ON_APPROVAL
}

enum AiProposalType {
  REPLACEMENT
  ADHOC
  CAPACITY
}

enum AiProposalState {
  DRAFT
  PENDING_EMPLOYEE_CONSENT
  EMPLOYEE_AGREED
  PENDING_MANAGER
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
}

enum ConsentState {
  NOT_ASKED
  PENDING
  GRANTED
  DECLINED
  EXPIRED
}

/// Kind of physical/logical access grant (Dostępy). Mirrors the TS `AccessType` const-object.
enum AccessType {
  CARD
  KEY
  PERMISSION
}

/// Lifecycle status of an AccessGrant. Mirrors the TS `AccessStatus` const-object.
enum AccessStatus {
  ACTIVE
  REVOKED
  LOST
}

model User {
  id             String               @id
  email          String               @unique
  keycloakSub    String               @unique @map("keycloak_sub")
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now()) @map("created_at")
  roles          UserRole[]
  managedUnits   OrganizationalUnit[] @relation("UnitManager")
  employee       Employee?
  leaveDecisions LeaveRequest[]       @relation("LeaveDecider")
  accessIssued   AccessGrant[]        @relation("AccessIssuer")

  @@map("users")
}

model UserRole {
  id     Int                 @id @default(autoincrement())
  userId String              @map("user_id")
  user   User                @relation(fields: [userId], references: [id])
  role   Role
  unitId String?             @map("unit_id")
  unit   OrganizationalUnit? @relation(fields: [unitId], references: [id])

  @@unique([userId, role, unitId])
  @@map("user_roles")
}

model OrganizationalUnit {
  id            String               @id @default(uuid())
  name          String
  parentId      String?              @map("parent_id")
  parent        OrganizationalUnit?  @relation("UnitTree", fields: [parentId], references: [id])
  children      OrganizationalUnit[] @relation("UnitTree")
  managerUserId String?              @map("manager_user_id")
  manager       User?                @relation("UnitManager", fields: [managerUserId], references: [id])
  roles         UserRole[]
  employees     Employee[]
  aiConfig      AiSchedulingConfig[]

  @@map("organizational_units")
}

model Employee {
  id             String             @id @default(uuid())
  userId         String?            @unique @map("user_id")
  user           User?              @relation(fields: [userId], references: [id])
  firstName      String             @map("first_name")
  lastName       String             @map("last_name")
  /// ENCRYPTED (AES-256-GCM, AAD-bound): build via @hrobot/db encryptEmployeePesel() — never assign a plaintext PESEL (RODO PII)
  pesel          String
  /// Blind index of pesel (HMAC-SHA256) for UNIQUE + lookup-by-PESEL; set via encryptEmployeePesel()
  peselHash      String             @unique @map("pesel_hash")
  position       String
  employmentType EmploymentType     @map("employment_type")
  hiredAt        DateTime           @map("hired_at")
  unitId         String             @map("unit_id")
  unit           OrganizationalUnit @relation(fields: [unitId], references: [id])
  /// ENCRYPTED (AES-256-GCM, AAD-bound) RODO PII — home address, used to derive homeLat/homeLng for
  /// haversine commute. Encrypt via @hrobot/shared EncryptionService before persisting; never store
  /// plaintext. Unlike `pesel` this is NOT looked up by value, so it needs no blind index.
  homeAddress    String?            @map("home_address")
  /// Home latitude for haversine commute (derived from homeAddress; not PII on its own).
  homeLat        Float?             @map("home_lat")
  /// Home longitude for haversine commute (derived from homeAddress; not PII on its own).
  homeLng        Float?             @map("home_lng")
  /// Contract fraction (etat). targetWeeklyHours = etat × 40. 1.0 = full-time.
  etat           Decimal            @default(1.0)
  /// Job qualifications the employee can cover (matched against ShiftDemand.requiredRole).
  qualifications String[]           @default([])
  /// SOFT preference: weekday codes (MON..SUN) the employee would rather NOT work. Optimized by the
  /// solver (preference soft-term), never hard-guaranteed. Additive; defaults to [] on existing rows.
  preferredDaysOff    String[]      @default([]) @map("preferred_days_off")
  /// SOFT preference: preferred shift start times as "HH:mm" strings. Optimized, never guaranteed.
  preferredShiftStart String[]      @default([]) @map("preferred_shift_start")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  shifts         Shift[]
  swapsRequested ShiftSwapRequest[] @relation("SwapRequester")
  swapsTargeted  ShiftSwapRequest[] @relation("SwapTarget")
  leaves         LeaveRequest[]
  aiProposalsVacated    AiProposal[]          @relation("AiProposalVacated")
  aiProposalCandidacies AiProposalCandidate[] @relation("AiProposalCandidateEmp")
  accessGrants   AccessGrant[]

  @@map("employees")
}

/// A physical site shifts are scheduled at. Minimal FK target for ShiftDemand/Shift.lokalizacjaId;
/// full facility attributes + web-kit seed reconciliation (facilityId string → UUID) land later (A5).
model Lokalizacja {
  id      String        @id @default(uuid())
  name    String
  /// Facility type; matches ShiftTemplate.lokalizacjaTyp (free-form, not an FK).
  typ     String
  /// Optional geolocation for haversine commute (nullable; may be geocoded later).
  lat     Float?
  lng     Float?
  demands ShiftDemand[]
  shifts  Shift[]
  accessGrants AccessGrant[]

  @@map("lokalizacje")
}

/// Reusable weekly staffing pattern for a location type. `okna` holds the demand windows as JSON
/// (`[{ start, end, rola, liczba }]`); expanding a template produces ShiftDemand rows (source=TEMPLATE).
model ShiftTemplate {
  id             String   @id @default(uuid())
  lokalizacjaTyp String   @map("lokalizacja_typ")
  nazwa          String
  /// Days of week the template applies to (e.g. ["MON","TUE"]).
  dni            String[] @default([])
  /// Demand windows: [{ start, end, rola, liczba }]. JSON keeps the skeleton simple; shape mirrors ShiftDemand.
  okna           Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("shift_templates")
}

/// Concrete staffing need: N employees of a role at a location for a dated window. Solver input.
model ShiftDemand {
  id            String       @id @default(uuid())
  lokalizacjaId String       @map("lokalizacja_id")
  lokalizacja   Lokalizacja  @relation(fields: [lokalizacjaId], references: [id])
  date          DateTime     @db.Date
  /// Window start/end as "HH:mm" local time (kept as text to avoid tz ambiguity in the skeleton).
  start         String
  end           String
  requiredRole  String       @map("required_role")
  requiredCount Int          @map("required_count")
  source        DemandSource @default(MANUAL)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  shifts        Shift[]

  @@map("shift_demands")
}

/// An assignment of one employee to one dated window at a location. Produced by the solver
/// (source=AUTO) or by a human (source=MANUAL). `demandId` links back to the need it fills (nullable
/// for manual shifts with no originating demand).
model Shift {
  id            String       @id @default(uuid())
  employeeId    String       @map("employee_id")
  employee      Employee     @relation(fields: [employeeId], references: [id])
  lokalizacjaId String       @map("lokalizacja_id")
  lokalizacja   Lokalizacja  @relation(fields: [lokalizacjaId], references: [id])
  demandId      String?      @map("demand_id")
  demand        ShiftDemand? @relation(fields: [demandId], references: [id])
  date          DateTime     @db.Date
  /// Window start/end as "HH:mm" local time (see ShiftDemand).
  start         String
  end           String
  role          String
  source        ShiftSource  @default(AUTO)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  swapsAsRequesterShift ShiftSwapRequest[] @relation("SwapRequesterShift")
  swapsAsTargetShift    ShiftSwapRequest[] @relation("SwapTargetShift")
  aiProposals           AiProposal[]

  @@map("shifts")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String   @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  payload     Json
  ipAddress   String   @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_log")
}

/// Singleton tenant-wide company settings (Ustawienia). Uniqueness of the single row is enforced by
/// a manual partial-unique index (`company_settings_singleton`) appended to the generated migration
/// SQL, since Prisma has no native "singleton table" construct.
model CompanySettings {
  id          String   @id @default(uuid())
  companyName String   @map("company_name")
  timezone    String   @default("Europe/Warsaw")
  region      String   @default("EU-Central")
  locale      String   @default("pl-PL")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("company_settings")
}

/// A worker-initiated shift-swap request (M2 #3). A 1:1 swap (both target fields set) or a
/// "give away shift" (target fields null). Never mutates `Shift` until APPROVED; the state
/// machine (apps/tenant-runtime src/shift-swap) drives transitions and performs the atomic
/// employeeId swap + audit on approval.
model ShiftSwapRequest {
  id                  String    @id @default(uuid())
  requesterEmployeeId String    @map("requester_employee_id")
  requester           Employee  @relation("SwapRequester", fields: [requesterEmployeeId], references: [id])
  requesterShiftId    String    @map("requester_shift_id")
  requesterShift      Shift     @relation("SwapRequesterShift", fields: [requesterShiftId], references: [id])
  /// Null for a "give away shift" request (no counterparty); set for a 1:1 swap.
  targetEmployeeId    String?   @map("target_employee_id")
  target              Employee? @relation("SwapTarget", fields: [targetEmployeeId], references: [id])
  targetShiftId       String?   @map("target_shift_id")
  targetShift         Shift?    @relation("SwapTargetShift", fields: [targetShiftId], references: [id])
  state               SwapState @default(DRAFT)
  reason              String?
  /// Manager who took the approve/reject decision (set on the manager decision only).
  decidedByManagerId  String?   @map("decided_by_manager_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("shift_swap_requests")
}

/// An employee's leave (urlop) over a closed date interval [startDate, endDate]. APPROVED rows that
/// overlap a solve week feed the grafik solver as `approvedLeaveDates` — an H3 hard constraint (the
/// employee cannot be scheduled on those dates). `type` is the leave kind as a free-form string
/// (URLOP_WYPOCZYNKOWY etc.), intentionally not modelled as an enum. Additive; never mutates Shift.
model LeaveRequest {
  id         String      @id @default(uuid())
  employeeId String      @map("employee_id")
  employee   Employee    @relation(fields: [employeeId], references: [id])
  startDate  DateTime    @map("start_date") @db.Date
  endDate    DateTime    @map("end_date") @db.Date
  status     LeaveStatus @default(PENDING)
  /// Leave kind (URLOP_WYPOCZYNKOWY, URLOP_NA_ZADANIE, …). Free-form string, not over-modelled.
  type       String
  /// Manager/HR who took the approve/reject/cancel decision (set on decision only).
  decidedByUserId String? @map("decided_by_user_id")
  decidedBy       User?   @relation("LeaveDecider", fields: [decidedByUserId], references: [id])
  decidedAt       DateTime? @map("decided_at")
  reason          String?
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([employeeId, startDate, endDate])
  @@map("leave_requests")
}

/// Per-unit (or global, when unitId is null) configuration for the AI Grafik Manager's autonomy
/// level and guardrails. `@@unique([unitId])` alone does not prevent multiple unit-less "default"
/// rows in Postgres (NULL is never equal to NULL for uniqueness purposes) — a partial unique index
/// on `unit_id IS NULL` is appended to the generated migration SQL to enforce a single default.
model AiSchedulingConfig {
  id              String             @id @default(uuid())
  unitId          String?            @map("unit_id")
  unit            OrganizationalUnit? @relation(fields: [unitId], references: [id])
  autonomyLevel   AutonomyLevel      @default(SUGGEST_ONLY) @map("autonomy_level")
  quietHoursStart String?            @map("quiet_hours_start")
  quietHoursEnd   String?            @map("quiet_hours_end")
  consentTtlHours Int                @default(24) @map("consent_ttl_hours")
  budgetWeeklyCap Decimal?           @map("budget_weekly_cap")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([unitId])
  @@map("ai_scheduling_config")
}

/// An AI-generated proposal to fill a vacated shift (replacement), place an ad-hoc assignment, or
/// address a capacity gap. Never mutates `Shift` directly — the state machine (a later phase) drives
/// consent/approval transitions and performs the atomic assignment only on APPROVED.
model AiProposal {
  id                  String                 @id @default(uuid())
  type                AiProposalType         @default(REPLACEMENT)
  state               AiProposalState        @default(DRAFT)
  shiftId             String                 @map("shift_id")
  shift               Shift                  @relation(fields: [shiftId], references: [id])
  vacatedEmployeeId   String                 @map("vacated_employee_id")
  vacatedEmployee     Employee               @relation("AiProposalVacated", fields: [vacatedEmployeeId], references: [id])
  activeCandidateId   String?                @map("active_candidate_id")
  reason              String?
  estimatedCost       Decimal?               @map("estimated_cost")
  decidedByManagerId  String?                @map("decided_by_manager_id")
  expiresAt           DateTime?              @map("expires_at")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")
  candidates          AiProposalCandidate[]

  @@index([state])
  @@index([shiftId])
  @@map("ai_proposal")
}

/// A ranked candidate employee for an AiProposal, with feasibility/score and per-candidate consent
/// tracking (an employee must GRANT consent before being committed to the vacated shift).
model AiProposalCandidate {
  id                 String       @id @default(uuid())
  proposalId         String       @map("proposal_id")
  proposal           AiProposal   @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  employeeId         String       @map("employee_id")
  employee           Employee     @relation("AiProposalCandidateEmp", fields: [employeeId], references: [id])
  rank               Int
  feasible           Boolean
  reason             String?
  score              Decimal?
  consentState       ConsentState @default(NOT_ASKED) @map("consent_state")
  consentRequestedAt DateTime?    @map("consent_requested_at")
  consentAt          DateTime?    @map("consent_at")

  @@unique([proposalId, employeeId])
  @@index([proposalId, rank])
  @@map("ai_proposal_candidate")
}

/// A physical/logical access grant for an employee (Dostępy): a card, key, or standalone permission.
/// `identifier` (e.g. card/key serial) is PII/security-sensitive. At most one ACTIVE grant may exist
/// per (type, identifier) pair — enforced by a partial unique index (`access_grant_active_identifier`)
/// appended to the generated migration SQL, since a re-issued/lost card's identifier may be reused
/// once the prior grant is REVOKED/LOST.
model AccessGrant {
  id             String       @id @default(uuid())
  employeeId     String       @map("employee_id")
  employee       Employee     @relation(fields: [employeeId], references: [id])
  type           AccessType
  label          String
  identifier     String?
  lokalizacjaId  String?      @map("lokalizacja_id")
  lokalizacja    Lokalizacja? @relation(fields: [lokalizacjaId], references: [id], onDelete: SetNull)
  status         AccessStatus @default(ACTIVE)
  issuedByUserId String?      @map("issued_by_user_id")
  issuedBy       User?        @relation("AccessIssuer", fields: [issuedByUserId], references: [id], onDelete: SetNull)
  issuedAt       DateTime     @default(now()) @map("issued_at")
  revokedAt      DateTime?    @map("revoked_at")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([employeeId])
  @@map("access_grant")
}
