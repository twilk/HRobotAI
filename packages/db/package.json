{
  "name": "@hrobot/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" } },
  "files": ["dist", "prisma", "generated"],
  "scripts": {
    "db:generate": "prisma generate --schema=prisma/control-plane/schema.prisma && prisma generate --schema=prisma/tenant/schema.prisma",
    "migrate:control:dev": "prisma migrate dev --schema=prisma/control-plane/schema.prisma",
    "migrate:tenant:dev": "prisma migrate dev --schema=prisma/tenant/schema.prisma",
    "migrate:control:deploy": "prisma migrate deploy --schema=prisma/control-plane/schema.prisma",
    "seed:admin:dev": "prisma db execute --schema=prisma/control-plane/schema.prisma --file=prisma/control-plane/seed-dev-admin.sql",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:integration": "jest --testMatch '**/*.integration.spec.ts' --passWithNoTests"
  },
  "dependencies": {
    "@hrobot/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "lru-cache": "^11.0.0"
  },
  "devDependencies": {
    "@hrobot/config": "workspace:*",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.13.0",
    "typescript-eslint": "^8.10.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
