# Turborepo cache
.turbo/

# Dependencies & build output
node_modules/
dist/
coverage/

# Prisma generated clients (regenerated via `pnpm db:generate`)
packages/db/generated/

# Env files (never commit secrets)
.env
.env.local
.env.*.local
!.env.example

# TypeScript incremental build info (generated per-package on build)
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
*.log

# Staging deploy runner-side state (web front + cloudflared pidfiles/logs — see infra/deploy/edge-up.sh)
.staging-run/

# Claude Code / gstack harness files (not project source)

# Local dev-box compose override (host-port remaps for shared box)
docker-compose.override.yml
