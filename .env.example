# HRobot control plane — copy to .env and adjust. Values below match docker-compose.yml
# so a fresh clone runs end-to-end with `docker compose up -d`.

# --- Postgres ---------------------------------------------------------------
# Control-plane database (Prisma migrates + reads/writes this one).
CONTROL_PLANE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hrobot_control
# Superuser connection used to CREATE per-tenant databases during provisioning.
# Points at the always-present `postgres` maintenance DB on the same instance.
POSTGRES_SUPERUSER_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Tenant DB encryption ---------------------------------------------------
# 32-byte AES-256 key, hex-encoded (exactly 64 hex chars). DEV PLACEHOLDER —
# regenerate for any shared/real env:  openssl rand -hex 32
TENANT_DB_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- Keycloak ---------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
# Admin client the provisioning KEYCLOAK_SETUP step authenticates as. The dev
# Keycloak (admin/admin) needs this confidential client created once — see README.
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_CLIENT_SECRET=dev-only-change-me

# --- Redis / RabbitMQ -------------------------------------------------------
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# --- Secrets (use long random values outside dev) ---------------------------
NEXTAUTH_SECRET=dev-nextauth-secret-change-me-please
# Min 32 chars. Signs the global-admin JWT.
GLOBAL_ADMIN_JWT_SECRET=dev-global-admin-jwt-secret-change-me-please

# --- API --------------------------------------------------------------------
# Optional; apps/api defaults to 3000.
PORT=3000
